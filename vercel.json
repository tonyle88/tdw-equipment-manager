{
  "version": 2,
  "rewrites": [
    {
      "source": "/",
      "destination": "/app/index.html"
    },
    {
      "source": "/styles.css",
      "destination": "/app/styles.css"
    },
    {
      "source": "/app.js",
      "destination": "/app/app.js"
    },
    {
      "source": "/config.js",
      "destination": "/app/config.js"
    },
    {
      "source": "/assets/:path*",
      "destination": "/app/assets/:path*"
    }
  ],
  "headers": [
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
